# Copy this file to .env locally and fill real values.
# Never commit .env.

# Backend
BACKEND_PORT=8081

# PostgreSQL for Spring Boot
DB_URL=jdbc:postgresql://localhost:5432/pfe_db
DB_USERNAME=postgres
DB_PASSWORD=change-me

# PostgreSQL for Python utility scripts
DB_NAME=pfe_db
DB_HOST=localhost
DB_PORT=5432

# JWT
# Must be a strong random secret, at least 32 bytes for HS256.
JWT_SECRET=replace-with-a-strong-random-secret-at-least-32-bytes
JWT_EXPIRATION_MS=86400000

# AES encryption for persisted Jira tokens
# Must be exactly 16, 24, or 32 bytes.
APP_ENCRYPTION_KEY=replace-with-32-byte-secret-value

# Jira OAuth
JIRA_CLIENT_ID=replace-with-jira-client-id
JIRA_CLIENT_SECRET=replace-with-jira-client-secret
JIRA_REDIRECT_URI=http://localhost:8081/api/jira/callback

# Xray Cloud
XRAY_CLIENT_ID=replace-with-xray-client-id
XRAY_CLIENT_SECRET=replace-with-xray-client-secret

# SMTP
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=replace-with-mail-username
MAIL_PASSWORD=replace-with-mail-app-password
MAIL_FROM_ADDRESS=noreply@Test2i.com
MAIL_FROM_NAME=TEST2i

# OTP
OTP_EXPIRATION_MINUTES=10
OTP_MAX_RESEND_ATTEMPTS=3
OTP_RESEND_BLOCK_MINUTES=15

# Hugging Face used by Spring chatbot
HUGGINGFACE_API_KEY=replace-with-huggingface-token
HUGGINGFACE_MODEL=HuggingFaceH4/zephyr-7b-beta
HUGGINGFACE_ENDPOINT=https://api-inference.huggingface.co/models/HuggingFaceH4/zephyr-7b-beta

# Hugging Face used by FastAPI AI service
HF_TOKEN=replace-with-huggingface-token
